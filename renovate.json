{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "minimumReleaseAge": "3 days"
    },
    {
      "minimumReleaseAge": "0 days",
      "matchCategories": [
        "vulnerability"
      ],
      "labels": [
        "security"
      ]
    },
    {
      "matchUpdateTypes": [
        "patch"
      ],
      "automergeType": "pr",
      "automerge": true
    }
  ]
}
