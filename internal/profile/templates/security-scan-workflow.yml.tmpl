# Security scanning workflow
# Generated by qsdev — do not edit manually.
name: Security Scan

on:
  pull_request:
  push:
    branches: [main, master]
  schedule:
    - cron: '0 6 * * 1'

permissions:
  contents: read

jobs:
  security-scan:
    runs-on: ubuntu-latest
    permissions:
      contents: read
      security-events: write
    steps:
{{- if .HasHardenRunner }}
      - name: Harden Runner
        uses: step-security/harden-runner@9af89fc71515a100421586dfdb3dc9c984fbf411 # v2.19.4
        with:
          egress-policy: audit
{{ end }}
      - name: Checkout
        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2

      - name: Validate lock files
        run: |
          echo "Checking lock file integrity..."
          # Verify lock files exist and are committed
          for f in package-lock.json pnpm-lock.yaml yarn.lock Cargo.lock go.sum poetry.lock uv.lock; do
            if [ -f "$f" ]; then
              echo "  ✓ $f present"
              git diff --exit-code "$f" || echo "  WARNING: $f has uncommitted changes"
            fi
          done
{{- if .HasOSV }}

      - name: OSV Scanner
        uses: google/osv-scanner-action/osv-scanner-action@9a498708959aeaef5ef730655706c5a1df1edbc2 # v2.3.8
        with:
          scan-args: |-
            --recursive
            .
{{- end }}
{{- if .HasSnyk }}

      - name: Snyk Security Scan
        uses: snyk/actions@9cf6ca713d71123d2d229cc3d7f145b96ea3c518 # master
        env:
          SNYK_TOKEN: ${{ "{{" }} secrets.SNYK_TOKEN {{ "}}" }}
        with:
          args: --all-projects
{{- end }}
{{- if .HasGrype }}

      - name: Grype Vulnerability Scan
        uses: anchore/scan-action@1638637db639e0ade3258b51db49a9a137574c3e # v6
        with:
          path: "."
          fail-build: true
{{- end }}
