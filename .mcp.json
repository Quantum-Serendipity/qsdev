{
  "mcpServers": {
    "agent-postmortem": {
      "command": "qsdev",
      "args": [
        "mcp",
        "agent-postmortem"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "@anthropic-ai/mcp-github"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "local-docs-devdocs": {
      "command": "npx",
      "args": [
        "devdocs-mcp-server"
      ],
      "env": {
        "DEVDOCS_DATA_DIR": "${HOME}/.local/share/qsdev/docs/devdocs"
      }
    },
    "semble": {
      "command": "uvx",
      "args": [
        "--from",
        "semble[mcp]",
        "semble"
      ]
    },
    "socket": {
      "type": "http",
      "url": "https://mcp.socket.dev/"
    },
    "version-sentinel": {
      "command": "qsdev",
      "args": [
        "mcp",
        "version-sentinel"
      ]
    }
  }
}
